# ═══════════════════════════════════════════════════════════════
# FORGE Environment Configuration
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ═══════════════════════════════════════════════════════════════

# ─────────────────────────────────────────────
# Application
# ─────────────────────────────────────────────
APP_NAME=FORGE
APP_VERSION=0.1.0
DEBUG=false
ENVIRONMENT=development

# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-in-production-32-chars-min

# API settings
API_PREFIX=/api/v1
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4

# ─────────────────────────────────────────────
# Database (PostgreSQL + pgvector)
# ─────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://forge:forge@localhost:5432/forge
DATABASE_SYNC_URL=postgresql://forge:forge@localhost:5432/forge
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20
DATABASE_POOL_TIMEOUT=30
DATABASE_POOL_RECYCLE=1800
DATABASE_ECHO=false

# PostgreSQL Container settings
POSTGRES_USER=forge
POSTGRES_PASSWORD=forge
POSTGRES_DB=forge
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# ─────────────────────────────────────────────
# Redis
# ─────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
REDIS_MAX_CONNECTIONS=50

# Celery uses separate Redis databases to avoid key collisions
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2
CELERY_TASK_SERIALIZER=json
CELERY_RESULT_SERIALIZER=json
CELERY_ACCEPT_CONTENT=json
CELERY_TIMEZONE=UTC
CELERY_ENABLE_UTC=true
CELERY_TASK_TRACK_STARTED=true
CELERY_TASK_TIME_LIMIT=3600
CELERY_TASK_SOFT_TIME_LIMIT=3300
CELERY_WORKER_CONCURRENCY=4
CELERY_WORKER_MAX_TASKS_PER_CHILD=1000

# ─────────────────────────────────────────────
# Neo4j (Knowledge Graph)
# ─────────────────────────────────────────────
NEO4J_URL=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=forge-neo4j-password
NEO4J_DATABASE=neo4j
NEO4J_MAX_CONNECTION_POOL_SIZE=50
NEO4J_CONNECTION_TIMEOUT=30

# ─────────────────────────────────────────────
# Temporal (Workflow Orchestration)
# ─────────────────────────────────────────────
TEMPORAL_HOST=localhost:7233
TEMPORAL_NAMESPACE=forge-default
TEMPORAL_TASK_QUEUE=forge-main
TEMPORAL_MAX_CONCURRENT_ACTIVITIES=100
TEMPORAL_MAX_CONCURRENT_WORKFLOWS=50

# ─────────────────────────────────────────────
# AI / LLM Providers
# ─────────────────────────────────────────────
# Anthropic Claude
ANTHROPIC_API_KEY=sk-ant-api03-...

# OpenAI (fallback / embeddings)
OPENAI_API_KEY=sk-proj-...

# Default model settings
DEFAULT_LLM_PROVIDER=anthropic
DEFAULT_LLM_MODEL=claude-3-5-sonnet-20241022
DEFAULT_EMBEDDING_MODEL=text-embedding-3-small
LLM_MAX_TOKENS=8192
LLM_TEMPERATURE=0.1
LLM_MAX_RETRIES=3

# ─────────────────────────────────────────────
# GitHub Integration
# ─────────────────────────────────────────────
GITHUB_TOKEN=ghp_...
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY_PATH=
GITHUB_WEBHOOK_SECRET=
GITHUB_DEFAULT_ORG=

# ─────────────────────────────────────────────
# Deployment Providers
# ─────────────────────────────────────────────
# Vercel
VERCEL_TOKEN=
VERCEL_TEAM_ID=
VERCEL_DEFAULT_PROJECT_NAME=

# Railway
RAILWAY_TOKEN=
RAILWAY_DEFAULT_PROJECT_ID=

# ─────────────────────────────────────────────
# AWS (for production infrastructure)
# ─────────────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_S3_BUCKET=forge-artifacts
AWS_S3_REGION=us-east-1

# ─────────────────────────────────────────────
# Observability
# ─────────────────────────────────────────────
# Sentry error tracking
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=0.1

# OpenTelemetry
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=forge-api
OTEL_RESOURCE_ATTRIBUTES=service.version=0.1.0

# Prometheus
PROMETHEUS_ENABLED=true
PROMETHEUS_PORT=9090

# ─────────────────────────────────────────────
# Logging
# ─────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_FILE=
LOG_MAX_SIZE=100
LOG_BACKUP_COUNT=5

# ─────────────────────────────────────────────
# Security & CORS
# ─────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000
CORS_ALLOW_CREDENTIALS=true
CORS_ALLOW_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS
CORS_ALLOW_HEADERS=*

# JWT settings
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Rate limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_PERIOD=60

# ─────────────────────────────────────────────
# Frontend (Next.js)
# ─────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000
NEXT_PUBLIC_APP_NAME=FORGE
NODE_ENV=development

# ─────────────────────────────────────────────
# Build metadata (injected by CI)
# ─────────────────────────────────────────────
BUILD_DATE=
GIT_COMMIT=
